# Server port and bind address (default 127.0.0.1:5757, local machine only)
# Permanent URL: http://localhost:5757
PORT=5757
HOST=127.0.0.1

# Data directory (default ~/.wewrite-studio)
# WEWRITE_DATA_DIR=

# These can also be set in the in-app Settings (in-app values take precedence)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.4-mini
WECHAT_APPID=
WECHAT_APPSECRET=
