{
  "name": "wechat-writing-studio",
  "version": "0.1.4",
  "description": "A local AI-assisted writing desk for WeChat Official Account publishing.",
  "author": "Allen",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "pack": "electron-builder --mac dir",
    "dist": "electron-builder --mac dmg"
  },
  "build": {
    "appId": "com.codex.wechatwritingstudio",
    "productName": "WeWrite Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "services/**/*",
      "renderer/**/*",
      "assets/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "dir"
      ]
    }
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1"
  }
}
